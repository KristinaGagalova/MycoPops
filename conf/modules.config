/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Process parameters (ext.args) — matching the standalone alignment script
      - BWAMEM2_MEM        : -M  + read group
      - PICARD_MARKDUPLICATES : --TAGGING_POLICY All
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    withName: 'BWAMEM2_MEM' {
	ext.args = { "-M -R \"@RG\\tID:${meta.id}\\tSM:${meta.id}\"" }
    }

    withName: 'PICARD_MARKDUPLICATES' {
        // ext.prefix is required: input and output BAM would otherwise share a name
        ext.prefix = { "${meta.id}.markdup" }
        // TAGGING_POLICY=All from the script (GNU-style spelling for Picard 3.x module)
        ext.args   = '--TAGGING_POLICY All'
    }

}

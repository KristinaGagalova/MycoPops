// Profile configurations
// Setonix Pawsey HPC profile configuration
// This file defines the pawsey_setonix profile

// Use the nf-core Setonix base configuration
includeConfig 'https://raw.githubusercontent.com/nf-core/configs/master/conf/pawsey_setonix.config'

// Override and add Setonix-specific settings for your pipeline
process {
    // Set work directory to scratch
    workDir = "${System.getenv('MYSCRATCH')}/nxf_work"

    // Setonix-specific resource adjustments
}

// Executor configuration (this will override the nf-core settings if needed)
executor {
    name = 'slurm'
    queueSize = 50  // Reduced from 1024 to be more reasonable
    submitRateLimit = '10 sec'
}

// Singularity configuration for Setonix
singularity {
    enabled = true
    autoMounts = true
    cacheDir = "${System.getenv('MYSOFTWARE')}/.nextflow_singularity"
    runOptions = '--cleanenv --bind /scratch,/group,/software'
    envWhitelist = 'SINGULARITY_BINDPATH,SINGULARITYENV_LD_LIBRARY_PATH,SINGULARITYENV_LD_PRELOAD'
}

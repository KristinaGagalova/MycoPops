/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    MycoPops Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Global default params
params {
    // Input/output
    input           = null
    outdir          = './results'
    manifest_sep    = ','      // Use '\t' for TSV manifests

    // Reference genome
    fasta           = null
    bwamem2_index   = null     // Path to bwa-mem2 index directory
    genome_size     = null     // e.g. 139956545 for Bgt genome

    // Max resource limits
    max_memory      = '128.GB'
    max_cpus        = 64
    max_time        = '24.h'
}

// Load base and module configs
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// Container engine profiles
profiles {
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        singularity.enabled    = false
        conda.enabled          = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
    }
    test {
        includeConfig 'conf/test.config'
    }
    slurm {
        includeConfig 'conf/slurm.config'
    }
}

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']

// Workflow metadata
manifest {
    name            = 'MycoPop'
    author          = 'Dr Kristina Gagalova, Dr Grace Fang'
    homePage        = 'https://github.com/KristinaGagalova/MycoPops'
    description     = 'Fungal population genotyping and admixture analysis from WGS reads'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '0.0.1'
}

// Tracing / reporting
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.html"
}
